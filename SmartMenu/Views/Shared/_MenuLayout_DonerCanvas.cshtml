@using SmartMenu.Models.Theme.Menu
@model SmartMenu.Models.View.PublicMenuViewModel
@{
    var rtl = Model.IsRtl ? "rtl" : "ltr";

    var theme = string.IsNullOrWhiteSpace(Model.MenuThemeJson)
        ? new MenuTheme_DonerCanvas()
        : System.Text.Json.JsonSerializer.Deserialize<MenuTheme_DonerCanvas>(Model.MenuThemeJson) ?? new MenuTheme_DonerCanvas();
}
<!DOCTYPE html>
<html lang="@Model.SelectedLanguage" dir="@rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link href="~/css/menu_donercanvas.css" rel="stylesheet" asp-append-version="true" />

    <style>
        @Html.Raw($":root {{--dnr-body-bg: {theme.BodyBackgroundColor};--dnr-hero-start: {theme.HeroGradientSmokeColor};--dnr-hero-end: {theme.HeroGradientCharColor};--dnr-brush-opacity: {theme.BrushOpacity.ToString(System.Globalization.CultureInfo.InvariantCulture)};--dnr-title: {theme.TitleColor};--dnr-title-size: {theme.TitleFontSize}rem;--dnr-search-bg: {theme.SearchBackgroundColor};--dnr-search-placeholder: {theme.SearchPlaceholderColor};--dnr-accent: {theme.EmberAccentColor};--dnr-section-title: {theme.SectionTitleColor};--dnr-canvas-line: {theme.CanvasLineColor};}}")
    </style>
</head>
<body>
    <div class="dnr-topbar">
        <div class="container-fluid px-2 px-md-3">
            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                @RenderSection("LanguageSelector", required: false)
                @if (Model.TenantIsUsingCommands)
                {
                    @RenderSection("CommandSelector", required: false)
                }
                else
                {
                    { IgnoreSection("CommandSelector"); }
                }
            </div>
        </div>
    </div>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>