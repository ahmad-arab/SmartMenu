@model SmartMenu.Models.Theme.Category.CategoryCardTheme_DonerCanvas
<div class="vstack gap-2">
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Card Matte Start</label>
      <input class="form-control form-control-sm" name="CardBackgroundStart" value="@Model.CardBackgroundStart" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Card Matte End</label>
      <input class="form-control form-control-sm" name="CardBackgroundEnd" value="@Model.CardBackgroundEnd" type="color" />
    </div>
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Brush Border Color</label>
      <input class="form-control form-control-sm" name="BorderColor" value="@Model.BorderColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Border Width (px)</label>
      <input class="form-control form-control-sm" name="BorderWidthPx" value="@Model.BorderWidthPx" type="number" />
    </div>
  </div>
  <div>
    <label class="form-label">Corner Radius (px)</label>
    <input class="form-control form-control-sm" name="BorderRadiusPx" value="@Model.BorderRadiusPx" type="number" />
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Category Title Color</label>
      <input class="form-control form-control-sm" name="TitleColor" value="@Model.TitleColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Category Title Size (rem)</label>
      <input class="form-control form-control-sm" name="TitleFontSize" value="@Model.TitleFontSize" type="number" step="0.05" />
    </div>
  </div>
  <div>
    <label class="form-label">Category Title Font</label>
    <input class="form-control form-control-sm" name="TitleFont" value="@Model.TitleFont" />
  </div>
  <div>
    <label class="form-label">Drop Shadow Intensity (0-1)</label>
    <input class="form-control form-control-sm" name="ShadowOpacity" value="@Model.ShadowOpacity" type="number" step="0.05" min="0" max="1" />
  </div>
</div>