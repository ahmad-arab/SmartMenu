@model SmartMenu.Models.Theme.Menu.MenuTheme_DonerCanvas
<div class="vstack gap-2">
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Canvas Background</label>
      <input class="form-control form-control-sm" name="BodyBackgroundColor" value="@Model.BodyBackgroundColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Canvas Line Color</label>
      <input class="form-control form-control-sm" name="CanvasLineColor" value="@Model.CanvasLineColor" type="color" />
    </div>
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Hero Matte Start</label>
      <input class="form-control form-control-sm" name="HeroGradientSmokeColor" value="@Model.HeroGradientSmokeColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Hero Matte End</label>
      <input class="form-control form-control-sm" name="HeroGradientCharColor" value="@Model.HeroGradientCharColor" type="color" />
    </div>
  </div>
  <div>
    <label class="form-label">Brush Stroke Opacity (0-1)</label>
    <input class="form-control form-control-sm" name="BrushOpacity" value="@Model.BrushOpacity" type="number" step="0.05" min="0" max="1" />
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Restaurant Name Color</label>
      <input class="form-control form-control-sm" name="TitleColor" value="@Model.TitleColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Name Size (rem)</label>
      <input class="form-control form-control-sm" name="TitleFontSize" value="@Model.TitleFontSize" type="number" step="0.05" />
    </div>
  </div>
  <div>
    <label class="form-label">Name Font</label>
    <input class="form-control form-control-sm" name="TitleFont" value="@Model.TitleFont" />
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Search Background</label>
      <input class="form-control form-control-sm" name="SearchBackgroundColor" value="@Model.SearchBackgroundColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Search Placeholder</label>
      <input class="form-control form-control-sm" name="SearchPlaceholderColor" value="@Model.SearchPlaceholderColor" type="color" />
    </div>
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Orange Accent</label>
      <input class="form-control form-control-sm" name="EmberAccentColor" value="@Model.EmberAccentColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Section Heading</label>
      <input class="form-control form-control-sm" name="SectionTitleColor" value="@Model.SectionTitleColor" type="color" />
    </div>
  </div>
</div>