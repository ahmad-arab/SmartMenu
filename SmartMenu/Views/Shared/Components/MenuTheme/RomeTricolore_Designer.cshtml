@model SmartMenu.Models.Theme.Menu.MenuTheme_RomeTricolore
<div class="vstack gap-2">
  <div>
    <label class="form-label">Smoky Background</label>
    <input class="form-control form-control-sm" name="BodyBackgroundColor" value="@Model.BodyBackgroundColor" type="color" />
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Smoke Layer Color</label>
      <input class="form-control form-control-sm" name="SmokeLayerColor" value="@Model.SmokeLayerColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Smoke Veil Color</label>
      <input class="form-control form-control-sm" name="SmokeVeilColor" value="@Model.SmokeVeilColor" type="color" />
    </div>
  </div>
  <div>
    <label class="form-label">Surface Color</label>
    <input class="form-control form-control-sm" name="SurfaceColor" value="@Model.SurfaceColor" type="color" />
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Title Color</label>
      <input class="form-control form-control-sm" name="TitleColor" value="@Model.TitleColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Title Size (rem)</label>
      <input class="form-control form-control-sm" name="TitleFontSize" value="@Model.TitleFontSize" type="number" step="0.05" />
    </div>
  </div>
  <div>
    <label class="form-label">Title Font</label>
    <input class="form-control form-control-sm" name="TitleFont" value="@Model.TitleFont" />
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Search Background</label>
      <input class="form-control form-control-sm" name="SearchBackgroundColor" value="@Model.SearchBackgroundColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Search Placeholder</label>
      <input class="form-control form-control-sm" name="SearchPlaceholderColor" value="@Model.SearchPlaceholderColor" type="color" />
    </div>
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Italian Green Accent</label>
      <input class="form-control form-control-sm" name="AccentGreen" value="@Model.AccentGreen" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Italian Red Accent</label>
      <input class="form-control form-control-sm" name="AccentRed" value="@Model.AccentRed" type="color" />
    </div>
  </div>
  <div class="row g-2">
    <div class="col">
      <label class="form-label">Section Title Color</label>
      <input class="form-control form-control-sm" name="SectionTitleColor" value="@Model.SectionTitleColor" type="color" />
    </div>
    <div class="col">
      <label class="form-label">Glass Border Color</label>
      <input class="form-control form-control-sm" name="GlassBorderColor" value="@Model.GlassBorderColor" type="color" />
    </div>
  </div>
</div>
