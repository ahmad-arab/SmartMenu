@using SmartMenu.Models.Theme.Category
@model SmartMenu.Models.Category.CategoryListItemViewModel
@{
    var theme = string.IsNullOrWhiteSpace(Model.ThemeJson)
        ? new CategoryCardTheme_Organic()
        : System.Text.Json.JsonSerializer.Deserialize<CategoryCardTheme_Organic>(Model.ThemeJson) ?? new CategoryCardTheme_Organic();

    var shadow = $"0 20px 46px rgba(0, 0, 0, {theme.ShadowOpacity.ToString(System.Globalization.CultureInfo.InvariantCulture)})";
    var url = string.IsNullOrWhiteSpace(Model.LinkUrl) ? "javascript:void(0)" : Model.LinkUrl;
}
<a href="@url" class="text-decoration-none d-block h-100" aria-label="@Model.DefaultTitle">
    <article class="org-category-card"
             style="
                background:linear-gradient(145deg, @theme.CardBackgroundStart, @theme.CardBackgroundEnd);
                border:@(theme.BorderWidthPx)px solid @theme.BorderColor;
                border-radius:@(theme.BorderRadiusPx)px;
                box-shadow:@shadow;
                --org-category-leaf:@theme.AccentLeafColor;
                --org-category-fruit:@theme.AccentFruitColor;
                --org-category-vein:@theme.VeinLineColor;
             ">
        <div class="org-category-image-wrap">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.DefaultTitle" class="org-category-image" />
            }
            else
            {
                <div class="org-category-image org-category-image-fallback"></div>
            }
            <span class="org-category-pattern" aria-hidden="true"></span>
            <span class="org-category-sticker" aria-hidden="true">Fresh</span>
        </div>

        <div class="org-category-content">
            <span class="org-category-leaf-mark" aria-hidden="true"></span>
            <h3 class="org-category-title"
                style="color:@theme.TitleColor; font-size:@(theme.TitleFontSize)rem; @(string.IsNullOrWhiteSpace(theme.TitleFont) ? "" : $"font-family:{theme.TitleFont};")">
                @Model.DefaultTitle
            </h3>
        </div>
    </article>
</a>
