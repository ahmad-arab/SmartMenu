@using SmartMenu.Models.Theme.Menu
@{
    var rtl = Model.IsRtl ? "rtl" : "ltr";

    var theme = string.IsNullOrWhiteSpace(Model.MenuThemeJson)
        ? new MenuTheme_RomeTricolore()
        : System.Text.Json.JsonSerializer.Deserialize<MenuTheme_RomeTricolore>(Model.MenuThemeJson) ?? new MenuTheme_RomeTricolore();

    var titleSize = theme.TitleFontSize.ToString(System.Globalization.CultureInfo.InvariantCulture);
}
<!DOCTYPE html>
<html lang="@Model.SelectedLanguage" dir="@rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&family=Noto+Kufi+Arabic:wght@400;600;700;800&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link href="~/css/menu_rometricolore.css" rel="stylesheet" asp-append-version="true" />

    <style>
        @Html.Raw($":root {{--rtm-bg:{theme.BodyBackgroundColor};--rtm-smoke-a:{theme.SmokeLayerColor};--rtm-smoke-b:{theme.SmokeVeilColor};--rtm-surface:{theme.SurfaceColor};--rtm-title:{theme.TitleColor};--rtm-title-size:{titleSize}rem;--rtm-search-bg:{theme.SearchBackgroundColor};--rtm-search-placeholder:{theme.SearchPlaceholderColor};--rtm-green:{theme.AccentGreen};--rtm-red:{theme.AccentRed};--rtm-section-title:{theme.SectionTitleColor};--rtm-glass:{theme.GlassBorderColor};--rtm-font-rtl-body:'Tajawal','Noto Kufi Arabic','Segoe UI',sans-serif;--rtm-font-rtl-display:'Noto Kufi Arabic','Tajawal','Segoe UI',sans-serif;}}")
    </style>
</head>
<body>
    <div class="rtm-smoke-layer" aria-hidden="true"></div>
    <div class="rtm-topbar">
        <div class="d-flex justify-content-between align-items-center px-2">
            @RenderSection("LanguageSelector", required: false)
            @if (Model.TenantIsUsingCommands)
            {
                @RenderSection("CommandSelector", required: false)
            }
            else
            {
                { IgnoreSection("CommandSelector"); }
            }
        </div>
    </div>

    <main class="rtm-main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>
