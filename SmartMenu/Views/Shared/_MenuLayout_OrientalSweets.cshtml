@using SmartMenu.Models.Theme.Menu
@model SmartMenu.Models.View.PublicMenuViewModel
@{
    var rtl = Model.IsRtl ? "rtl" : "ltr";

    var theme = string.IsNullOrWhiteSpace(Model.MenuThemeJson)
        ? new MenuTheme_OrientalSweets()
        : System.Text.Json.JsonSerializer.Deserialize<MenuTheme_OrientalSweets>(Model.MenuThemeJson) ?? new MenuTheme_OrientalSweets();
}
<!DOCTYPE html>
<html lang="@Model.SelectedLanguage" dir="@rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link href="~/css/menu_orientalsweets.css" rel="stylesheet" asp-append-version="true" />

    <style>
        @Html.Raw($":root {{--os-body-bg: {theme.BodyBackgroundColor};--os-header-start: {theme.HeaderGradientStart};--os-header-end: {theme.HeaderGradientEnd};--os-surface: {theme.SurfaceColor};--os-title: {theme.TitleColor};--os-title-size: {theme.TitleFontSize}rem;--os-search-bg: {theme.SearchBackgroundColor};--os-search-placeholder: {theme.SearchPlaceholderColor};--os-accent: {theme.AccentColor};--os-section-title: {theme.SectionTitleColor};}}")
        body { background: var(--os-body-bg); }
        .os-topbar { position: absolute; top: .6rem; left: 0; right: 0; z-index: 1000; }
    </style>
</head>
<body>
    <div class="os-topbar">
        <div class="d-flex justify-content-between align-items-center px-2">
            @RenderSection("LanguageSelector", required: false)
            @if (Model.TenantIsUsingCommands)
            {
                @RenderSection("CommandSelector", required: false)
            }
            else
            {
                { IgnoreSection("CommandSelector"); }
            }
        </div>
    </div>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>
